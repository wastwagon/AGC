# Production URL (for Open Graph, SEO)
NEXT_PUBLIC_SITE_URL=https://www.africagovernancecentre.org

# Optional: Social links (icons hidden until set)
# NEXT_PUBLIC_TWITTER_URL=https://twitter.com/africagovernance
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/africa-governance-centre
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/africagovernancecentre
# NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/africagovernancecentre

# Optional: Override default images (must be /uploads/ paths from media library)
# Upload images at /admin/media, then set paths here
# NEXT_PUBLIC_HERO_IMAGE=/uploads/hero.jpg
# NEXT_PUBLIC_ABOUT_IMAGE=/uploads/about.jpg
# NEXT_PUBLIC_PROGRAMS_IMAGE=/uploads/programs.jpg
# NEXT_PUBLIC_PROJECTS_IMAGE=/uploads/projects.jpg
# NEXT_PUBLIC_ADVISORY_IMAGE=/uploads/advisory.jpg
# NEXT_PUBLIC_EVENTS_IMAGE=/uploads/events.jpg
# NEXT_PUBLIC_NEWS_IMAGE=/uploads/news.jpg
# NEXT_PUBLIC_GET_INVOLVED_IMAGE=/uploads/get-involved.jpg
# NEXT_PUBLIC_CONTACT_IMAGE=/uploads/contact.jpg
# NEXT_PUBLIC_APP_SUMMIT_IMAGE=/uploads/app-summit.jpg
# NEXT_PUBLIC_APPLICATIONS_IMAGE=/uploads/applications.jpg

# Optional: Hero slider images (comma-separated /uploads/ paths)
# NEXT_PUBLIC_HERO_SLIDER_IMAGES=/uploads/hero.jpg,/uploads/slide2.jpg,/uploads/slide3.jpg

# Optional: Sentry error monitoring
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=agc-site

# Admin authentication (required for /admin/*)
AUTH_SECRET=  # Generate with: openssl rand -base64 32
ADMIN_EMAIL=admin@africagovernancecentre.org
ADMIN_PASSWORD=changeme

# Optional: Analytics (use one)
# Google Analytics 4:
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Plausible (privacy-friendly):
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# PostgreSQL — CMS, admin, forms (required for /admin data pages)
# Local Docker Compose (repo root: docker compose up -d agc-db) exposes Postgres on host port 5436 by default:
# DATABASE_URL="postgresql://agc:agc_secret@localhost:5436/agc?schema=public"
# Or use your own Postgres (any port):
DATABASE_URL="postgresql://user:password@localhost:5432/agc?schema=public"

# Resend - Email delivery for contact form
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: Custom sender email (must be verified in Resend)
# Default: onboarding@resend.dev
RESEND_FROM_EMAIL=programs@africagovernancecentre.org
