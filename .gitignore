# OS
.DS_Store
Thumbs.db

# Local Docker Compose overrides (merge with docker-compose.yml; never commit)
docker-compose.override.yml

# Secrets — never commit (use .env.docker.example / agc-site/.env.example)
.env
.env.local
.env.*.local
!.env.example
!.env.docker.example

# Dependencies & build outputs
**/node_modules/
**/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js (agc-site)
agc-site/.next/
agc-site/out/
agc-site/build/
agc-site/coverage/
agc-site/.vercel
agc-site/*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# Prisma
**/src/generated/prisma

# Test / misc
*.pem
.turbo

# Cursor / local
.cursor/
