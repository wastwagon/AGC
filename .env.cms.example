# Africa Governance Centre — Docker Compose (full stack)
# Copy to .env in the repo root, then: docker compose up -d --build

# === Website ===
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# Admin login (/admin) — required in production Docker
AUTH_URL=https://yourdomain.com
AUTH_SECRET=   # openssl rand -base64 32
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=contact@yourdomain.com

# === Content + Event Registrations DB (Prisma) ===
AGC_DB_PASSWORD=agc_secret

# Optional: host port mappings (defaults: 9200 web, 5436 Postgres)
# WEB_PORT=9200
# POSTGRES_HOST_PORT=5436
