# Africa Governance Centre - Full Stack (Web + Event DB)
# Copy to .env and configure before: docker compose -f docker-compose.full.yml up -d

# === Website ===
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# Admin login (/admin) — required in production Docker
AUTH_URL=https://yourdomain.com
AUTH_SECRET=   # openssl rand -base64 32
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=contact@yourdomain.com

# === Content + Event Registrations DB (Prisma) ===
AGC_DB_PASSWORD=agc_secret
